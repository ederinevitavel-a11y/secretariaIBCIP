{
  "entities": {
    "Member": {
      "title": "Member",
      "description": "Church member registration data",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "dob": { "type": "string", "format": "date" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "maritalStatus": { "type": "string", "enum": ["Solteiro(a)", "Casado(a)", "Divorciado(a)", "Viúvo(a)"] },
        "originChurch": { "type": "string" },
        "photoUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "dob", "email", "phone", "address", "maritalStatus", "originChurch"]
    }
  },
  "firestore": {
    "/members/{memberId}": {
      "schema": "Member",
      "description": "Collection of church members"
    }
  }
}
